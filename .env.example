# =============================================================================
# CryoVault — Environment Configuration
# =============================================================================
#
# HOW TO USE THIS FILE
# --------------------
# 1. Copy this file:        cp .env.example .env
# 2. Edit .env with your    actual values (never commit .env to git)
# 3. The server reads       these at startup via process.env.*
#
# WHY ENVIRONMENT VARIABLES?
# --------------------------
# Hard-coding values like passwords or port numbers directly into source
# code is bad practice because:
#   - You can't change them without editing and redeploying code
#   - Secrets end up in version control history
#   - The same code can't run in dev/staging/production without edits
#
# Environment variables let one codebase serve all environments.
# =============================================================================


# -----------------------------------------------------------------------------
# SERVER
# -----------------------------------------------------------------------------

# The TCP port the Node.js HTTP server will listen on.
# Common choices: 3000 (dev), 8080 (behind a reverse proxy), 443 (direct HTTPS)
# When running behind nginx (recommended for production), keep this at 3000
# and let nginx handle the public-facing port 80/443.
PORT=3000

# The public URL of this service, used for CORS and self-referencing links.
# In development this is just localhost. In production use your actual domain.
# Do NOT include a trailing slash.
APP_URL=http://localhost:3000

# Application environment tag. Affects logging verbosity and error detail.
# Values: development | staging | production
NODE_ENV=development


# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------

# Filesystem path where SQLite will store its database file.
# - In development: a local file is fine (./cryovault.db)
# - In Docker: map this to a volume mount (see docker-compose.yml)
# - In production: put it on persistent storage outside the container
#   so it survives container restarts and image rebuilds.
DB_PATH=./data/cryovault.db

# SQLite Write-Ahead Logging (WAL) mode.
# WAL allows concurrent reads while a write is in progress, which is
# important if multiple browser tabs hit the server simultaneously.
# Leave as "true" unless you have a specific reason to disable it.
DB_WAL_MODE=true

# Maximum number of rows returned from the audit log in a single API request.
# Prevents memory issues if the audit table grows very large.
# Clients can paginate through results using ?page= and ?limit= parameters.
DB_AUDIT_MAX_ROWS=200


# -----------------------------------------------------------------------------
# CORS (Cross-Origin Resource Sharing)
# -----------------------------------------------------------------------------
# CORS is a browser security feature. When your frontend is served from
# origin A (e.g., https://cryo.mylab.org) and tries to call an API at
# origin B (e.g., https://api.mylab.org), the browser blocks the request
# UNLESS the API server explicitly allows it via CORS headers.
#
# CORS_ORIGIN controls which origins are allowed to call this API.
# Options:
#   *                          → Allow any origin (fine for development,
#                                 risky for production — anyone can call your API)
#   http://localhost:3000      → Only requests from this exact origin
#   https://cryo.mylab.org     → Only your production frontend
#   https://a.com,https://b.com → Comma-separated list of allowed origins
#
# When the frontend is served by the SAME Express server (the default setup),
# CORS is not needed at all — but the variable is here for when you split
# the frontend and backend to separate servers/domains.
CORS_ORIGIN=*


# -----------------------------------------------------------------------------
# AUTHENTICATION  (not yet implemented — placeholder for future expansion)
# -----------------------------------------------------------------------------
# These variables are here as a reminder that a real lab deployment will
# need authentication. Common choices:
#
#   Simple shared secret  → Add a header check (easy, one user)
#   JWT tokens            → Stateless, supports multiple users
#   OAuth2 / LDAP         → Integrate with your institution's identity provider
#
# JWT_SECRET is the signing key for JSON Web Tokens. If you add JWT auth,
# this MUST be a long, random string — never a dictionary word.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
#
# AUTH_ENABLED=false means all routes are publicly accessible (current state).
# Flip to true once you implement middleware that checks tokens.
AUTH_ENABLED=false
JWT_SECRET=CHANGE_ME_generate_a_real_random_secret_before_enabling_auth
JWT_EXPIRY=8h


# -----------------------------------------------------------------------------
# RATE LIMITING  (not yet implemented — placeholder)
# -----------------------------------------------------------------------------
# Rate limiting caps how many requests a single IP address can make in a
# time window. This protects against:
#   - Accidental loops in client code hammering the server
#   - Deliberate denial-of-service attempts
#
# RATE_LIMIT_WINDOW_MS  → Time window in milliseconds (900000 = 15 minutes)
# RATE_LIMIT_MAX        → Max requests per IP per window
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=500


# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
# Controls how much the server prints to stdout/stderr.
# In production, these logs are typically captured by Docker, systemd, or pm2
# and sent to a log aggregator (Datadog, Papertrail, ELK stack, etc.).
#
# LOG_LEVEL values (least → most verbose):
#   error  → only crashes and unhandled exceptions
#   warn   → recoverable problems (deprecated calls, slow queries)
#   info   → normal operational messages (server started, requests)
#   debug  → detailed trace useful while developing
LOG_LEVEL=info

# Whether to pretty-print logs (human-readable) or output newline-delimited
# JSON (machine-readable, better for log aggregators).
# Values: pretty | json
LOG_FORMAT=pretty


# -----------------------------------------------------------------------------
# FILE UPLOADS  (for future QR batch import or CSV import features)
# -----------------------------------------------------------------------------
# Maximum size of a single uploaded file (e.g., a JSON import file).
# Express's JSON body parser also uses this limit.
# Format: number of bytes, or a string like "10mb", "50mb"
UPLOAD_MAX_SIZE=50mb


# -----------------------------------------------------------------------------
# BACKUP
# -----------------------------------------------------------------------------
# CryoVault can automatically back up the SQLite database on a schedule.
# Backups are written to BACKUP_DIR, which docker-compose.yml bind-mounts
# to ./backups on your HOST machine — outside the container.
# This means backups survive even if the container or Docker volume is deleted.
#
# QUICK START
#   1. mkdir -p backups          ← create the host directory
#   2. Set BACKUP_ENABLED=true   ← enable the scheduler
#   3. docker compose down && docker compose up -d
#   4. Check logs: docker compose logs app | grep backup
#
# BACKUP_ENABLED   → true | false
# BACKUP_DIR       → /backups inside the container (bind-mounted to ./backups)
# BACKUP_SCHEDULE  → cron expression: "minute hour dom month dow"
#                    0 2 * * *  = 2:00 AM every day   (default)
#                    0 */6 * * * = every 6 hours
#                    0 2 * * 0  = 2:00 AM every Sunday
# BACKUP_KEEP_DAYS → delete backups older than this many days (0 = keep all)
#
# RESTORE from a backup (run on host):
#   docker compose stop app
#   gunzip -c backups/cryovault-2024-06-01_02-00-00.db.gz > data/cryovault.db
#   docker compose start app
BACKUP_ENABLED=false
BACKUP_DIR=/backups
BACKUP_SCHEDULE=0 2 * * *
BACKUP_KEEP_DAYS=30


# -----------------------------------------------------------------------------
# DOCKER / CONTAINER  (used by docker-compose.yml, not by Node directly)
# -----------------------------------------------------------------------------
# These are consumed by docker-compose.yml to configure the container runtime.
# They are NOT read by server.js — they live here for single-file convenience.

# Tag used when building the Docker image.
# Bump this with each release so you can roll back: e.g., 1.0.0, 1.1.0
DOCKER_IMAGE_TAG=latest

# Host port mapped to the container's PORT inside Docker.
# If PORT=3000 inside the container and DOCKER_HOST_PORT=8080,
# then  http://yourserver:8080  reaches the container.
DOCKER_HOST_PORT=3000

# Path on the HOST machine where the database file is stored.
# Docker mounts this directory into the container, so data persists
# even if you delete and recreate the container.
DOCKER_DB_VOLUME=./data
