# =============================================================================
# docker-compose.yml — CryoVault with self-contained nginx + SSL
# =============================================================================
#
# USAGE
#   1. Generate SSL certs first:   ./deploy/scripts/setup-ssl.sh
#   2. mkdir -p data backups
#   3. docker compose up -d
#
# PORTS
#   nginx listens on HTTPS_PORT (default 8443) for HTTPS
#   and HTTP_PORT (default 8080) which redirects to HTTPS.
#   Change these in .env if those ports are taken:
#     HTTP_PORT=8880
#     HTTPS_PORT=8443
#
# The app container is NOT exposed to the host — all traffic goes through nginx.
# =============================================================================

services:

  # ===========================================================================
  # Service: app — CryoVault Node.js Application
  # ===========================================================================
  app:
    build:
      context: .
      dockerfile: Dockerfile

    container_name: cryovault-app
    restart: unless-stopped

    environment:
      NODE_ENV: "${NODE_ENV:-production}"
      PORT: "${PORT:-3000}"
      DB_PATH: "${DB_PATH:-/data/cryovault.db}"
      CORS_ORIGIN: "${CORS_ORIGIN:-*}"
      LOG_LEVEL: "${LOG_LEVEL:-info}"
      DB_WAL_MODE: "${DB_WAL_MODE:-true}"
      DB_AUDIT_MAX_ROWS: "${DB_AUDIT_MAX_ROWS:-200}"
      UPLOAD_MAX_SIZE: "${UPLOAD_MAX_SIZE:-50mb}"
      BACKUP_ENABLED: "${BACKUP_ENABLED:-false}"
      BACKUP_DIR: "${BACKUP_DIR:-/backups}"
      BACKUP_SCHEDULE: "${BACKUP_SCHEDULE:-0 2 * * *}"
      BACKUP_KEEP_DAYS: "${BACKUP_KEEP_DAYS:-30}"

    volumes:
      - ./data:/data
      - ./backups:/backups

    # App is NOT exposed to the host — only nginx can reach it via the
    # internal Docker network. This means port 3000 is not accessible
    # from outside Docker, so there's no conflict with other services.
    expose:
      - "3000"

    networks:
      - internal

    healthcheck:
      test: ["CMD", "wget", "-qO-", "http://localhost:3000/api/health"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 10s


  # ===========================================================================
  # Service: nginx — HTTPS reverse proxy
  # ===========================================================================
  # Uses self-signed or Let's Encrypt certs from ./certs/
  # HTTP traffic is redirected to HTTPS automatically.
  nginx:
    image: nginx:1.25-alpine

    container_name: cryovault-nginx
    restart: unless-stopped

    ports:
      # Change HTTP_PORT / HTTPS_PORT in .env to avoid conflicts with other
      # services. Default: 8080 (HTTP redirect) and 44300 (HTTPS).
      - "${HTTP_PORT:-8080}:80"
      - "${HTTPS_PORT:-44300}:443"

    volumes:
      - ./deploy/nginx/nginx-ssl.conf:/etc/nginx/nginx.conf:ro
      - ./certs:/etc/nginx/certs:ro

    depends_on:
      - app

    networks:
      - internal


# =============================================================================
# NETWORKS
# =============================================================================
networks:
  internal:
    driver: bridge
    # Only app and nginx are on this network. The app is not reachable
    # from the host directly — all traffic goes through nginx.


# =============================================================================
# VOLUMES
# =============================================================================
volumes: {}
  # No named volumes — data persists in ./data/ and ./backups/ on the host.
