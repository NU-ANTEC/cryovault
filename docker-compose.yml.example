# =============================================================================
# docker-compose.yml — Multi-Container Orchestration
# =============================================================================
#
# WHAT IS DOCKER COMPOSE?
#   Docker Compose lets you define and run multiple containers as a single
#   service. In this file we define two containers ("services"):
#     1. app   — the CryoVault Node.js server
#     2. nginx — a reverse proxy that sits in front of the app
#
#   Instead of running two separate `docker run` commands with many flags,
#   you run one command:
#     docker compose up -d        ← start all services in the background
#     docker compose down         ← stop and remove containers
#     docker compose logs -f app  ← stream logs from the app container
#     docker compose ps           ← check container status
#
# WHY A REVERSE PROXY (nginx)?
#   The Node.js app listens only on an internal port (3000). nginx listens
#   on the public ports 80/443 and forwards requests to the app. This gives:
#   - TLS/HTTPS termination in one place (nginx handles SSL certs)
#   - Static file serving optimised in C, not JavaScript
#   - Gzip compression, rate limiting, and caching at the network edge
#   - The ability to run multiple apps on the same server with different domains
#   - The Node.js process never exposed directly to the internet
#
# USAGE
#   1. Copy .env.example to .env and fill in your values
#   2. docker compose up -d
#   3. Open http://localhost (or your domain if configured)
#
# The ${VARIABLE} syntax reads values from the .env file.
# =============================================================================

# Compose file format version. "3.8" is stable and supports all features used here.
version: "3.8"

services:

  # ===========================================================================
  # Service: app — CryoVault Node.js Application
  # ===========================================================================
  app:
    # Build the image from the Dockerfile in the current directory.
    # You can also replace "build:" with "image: cryovault:latest" if you
    # push the image to a registry (Docker Hub, GitHub Container Registry, etc.)
    # and pull it on the server instead of building on the server.
    build:
      context: .          # Look for Dockerfile in the current directory
      dockerfile: Dockerfile

    # Name the running container so you can reference it easily:
    #   docker logs cryovault-app
    #   docker exec -it cryovault-app sh
    container_name: cryovault-app

    # restart: unless-stopped means:
    #   - If the server reboots → container restarts automatically
    #   - If the app crashes   → container restarts automatically
    #   - If you stop it with `docker compose down` → stays stopped
    restart: unless-stopped

    # Environment variables passed into the container at runtime.
    # These OVERRIDE any ENV defaults baked into the Dockerfile.
    # Values come from the .env file (${VAR} syntax) with fallbacks (:-default).
    environment:
      NODE_ENV: "${NODE_ENV:-production}"
      PORT: "${PORT:-3000}"
      DB_PATH: "${DB_PATH:-/data/cryovault.db}"
      CORS_ORIGIN: "${CORS_ORIGIN:-*}"
      LOG_LEVEL: "${LOG_LEVEL:-info}"
      DB_WAL_MODE: "${DB_WAL_MODE:-true}"
      DB_AUDIT_MAX_ROWS: "${DB_AUDIT_MAX_ROWS:-200}"
      UPLOAD_MAX_SIZE: "${UPLOAD_MAX_SIZE:-50mb}"
      # Backup scheduler — set BACKUP_ENABLED=true in .env to activate
      BACKUP_ENABLED: "${BACKUP_ENABLED:-false}"
      BACKUP_DIR: "${BACKUP_DIR:-/backups}"
      BACKUP_SCHEDULE: "${BACKUP_SCHEDULE:-0 2 * * *}"
      BACKUP_KEEP_DAYS: "${BACKUP_KEEP_DAYS:-30}"

    volumes:
      # Database bind-mount: ./data/ on the HOST → /data inside the container.
      # A bind-mount is just a regular directory on your filesystem — git pull,
      # reboots, and `docker compose down -v` cannot touch it.
      # Create before first run:  mkdir -p data
      - ./data:/data
      # Backup bind-mount: backups land in ./backups/ on the host
      - ./backups:/backups

    # Port mapping: HOST_PORT:CONTAINER_PORT
    # We do NOT expose the app directly on port 80 — nginx handles that.
    # The app is reachable on the host at localhost:${DOCKER_HOST_PORT} (for
    # debugging), and nginx reaches it via the internal Docker network.
    # In production you can remove this entirely so the app is only reachable
    # through nginx.
    ports:
      - "${DOCKER_HOST_PORT:-3000}:${PORT:-3000}"

    # Networking: connect to the internal network so nginx can reach the app.
    # Services on the same Docker network can reach each other by service name.
    # Inside nginx.conf you'll see  proxy_pass http://app:3000  — "app" resolves
    # to this container's IP address automatically within the Docker network.
    networks:
      - internal

    # Health check at the Compose level mirrors the Dockerfile HEALTHCHECK.
    # Compose uses this to determine when the app is ready before starting
    # dependent services (if any were configured with "depends_on: condition: healthy").
    healthcheck:
      test: ["CMD", "wget", "-qO-", "http://localhost:3000/api/health"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 10s


  # ===========================================================================
  # Service: nginx — Reverse Proxy
  # ===========================================================================
  # HTTP-only configuration — no SSL certificates required.
  # To use HTTPS later, replace deploy/nginx/nginx.conf with the TLS version
  # and add your certificate files.
  nginx:
    image: nginx:1.25-alpine

    container_name: cryovault-nginx

    restart: unless-stopped

    # HOST_PORT:CONTAINER_PORT
    # nginx listens on port 80 inside the container.
    # Change the left number to use a different host port, e.g. "8080:80"
    ports:
      - "80:80"

    volumes:
      - ./deploy/nginx/nginx.conf:/etc/nginx/nginx.conf:ro

    depends_on:
      - app

    networks:
      - internal
      - external


# =============================================================================
# NETWORKS
# =============================================================================
# Docker networks are isolated virtual networks.
# Services on the same network can communicate with each other by service name.
# Services on different networks cannot (unless explicitly bridged).
#
# internal: only app and nginx are on this network. The app is not directly
#           reachable from outside Docker — all traffic must go through nginx.
# external: nginx is on this network, which connects to the host's network
#           interface (and thus to the internet or your LAN).
# =============================================================================
networks:
  internal:
    driver: bridge    # Standard Docker network type — creates a virtual switch
  external:
    driver: bridge


# =============================================================================
# VOLUMES
# =============================================================================
# Named volumes are managed by Docker and stored in /var/lib/docker/volumes/
# on the host (exact path varies by OS). They persist independently of
# containers — deleting a container does NOT delete a named volume.
#
# To back up: docker run --rm -v cryovault_data:/data -v $(pwd):/backup alpine \
#               tar czf /backup/cryovault-backup.tar.gz /data
#
# To restore: docker run --rm -v cryovault_data:/data -v $(pwd):/backup alpine \
#               tar xzf /backup/cryovault-backup.tar.gz -C /
# =============================================================================
volumes: {}
  # No named volumes — data persists in ./data/ and ./backups/ on the host.
